# SSH device connection (loaded by Rust backend only)
SSH_NAME=es
SSH_USER=es
SSH_HOST=10.80.80.221
SSH_PORT=22

# IP for Cloudflare DNS A records on the Proxy page (defaults to SSH_HOST)
# SERVER_DNS_IP=10.80.80.221

# Password login (same as: ssh es@10.80.80.221)
SSH_PASSWORD=your_ssh_password_here

# Or key-based login (comment out SSH_PASSWORD and use these instead)
# SSH_KEY_PATH=C:\Users\you\.ssh\id_ed25519
# SSH_KEY_PASSPHRASE=

# Reconnection tuning (milliseconds / seconds)
SSH_HEALTH_INTERVAL_SECS=30
SSH_STATS_INTERVAL_SECS=15
SSH_PROBE_FAILURE_THRESHOLD=3
SSH_INITIAL_RETRY_MS=1000
SSH_MAX_RETRY_MS=30000
SSH_CONNECT_TIMEOUT_SECS=15
SSH_EXEC_TIMEOUT_SECS=45

# ── OTA auto-update (Cloudflare R2 + Tauri updater) ─────────────────────────
# 1. Generate keys: npx tauri signer generate -w .tauri/mesh.key --ci
# 2. Paste the .pub file contents:
TAURI_UPDATER_PUBKEY=
# 3. Private key path for signing release bundles:
TAURI_SIGNING_PRIVATE_KEY_PATH=.tauri/mesh.key

# Public manifest URL (recommended — baked into release builds):
R2_UPDATE_MANIFEST_URL=https://pub-xxxx.r2.dev/latest.json

# R2 API credentials (optional fallback — presigns manifest at runtime):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=mesh-releases
# R2_MANIFEST_KEY=latest.json

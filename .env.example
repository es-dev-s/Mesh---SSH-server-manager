# SSH device connection (loaded by Rust backend only)
SSH_NAME=es
SSH_USER=es
SSH_HOST=10.80.80.221
SSH_PORT=22

# Password login (same as: ssh es@10.80.80.221)
SSH_PASSWORD=your_ssh_password_here

# Or key-based login (comment out SSH_PASSWORD and use these instead)
# SSH_KEY_PATH=C:\Users\you\.ssh\id_ed25519
# SSH_KEY_PASSPHRASE=

# Reconnection tuning (milliseconds / seconds)
SSH_HEALTH_INTERVAL_SECS=10
SSH_STATS_INTERVAL_SECS=15
SSH_INITIAL_RETRY_MS=2000
SSH_MAX_RETRY_MS=30000
SSH_CONNECT_TIMEOUT_SECS=15
SSH_EXEC_TIMEOUT_SECS=45
